# GitHub API Configuration
# Create a personal access token at: https://github.com/settings/tokens

# Required for SPACE metrics (PR data, reviews)
# Scopes needed: repo (classic) or fine-grained "Pull requests: read"
GITHUB_TOKEN=ghp_your_token_here

# Optional: GitHub organization name for Copilot metrics
# Required scopes: manage_billing:copilot or read:enterprise
GITHUB_ORG=your-org-name

# Optional: GitHub Enterprise slug for enterprise-level Copilot metrics
# Required scope: read:enterprise
GITHUB_ENTERPRISE=your-enterprise-slug

# Data Collection Configuration
DATA_DIR=devmetrics/data
LOG_LEVEL=INFO

# Copilot ROI Configuration
# Average time saved per accepted suggestion (in seconds)
TIME_SAVED_PER_ACCEPTANCE=55

# Average developer hourly rate (for $ calculations)
DEVELOPER_HOURLY_RATE=75
