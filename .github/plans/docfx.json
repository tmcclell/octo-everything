{
  "build": {
    "content": [
      {
        "files": ["**/*.md", "**/*.yml"],
        "exclude": ["_site/**", "**/node_modules/**"]
      }
    ],
    "resource": [
      {
        "files": ["**/images/**"]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_appTitle": "DevMetrics Wiki",
      "_appFooter": "DevMetrics Dashboard — Planning & Specifications",
      "_enableSearch": true,
      "_enableNewTab": true
    },
    "template": ["default", "modern"],
    "postProcessors": ["ExtractSearchIndex"]
  }
}
