# GitHub Personal Access Token (classic) with repo, read:org scopes
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Enterprise slug (for Copilot metrics)
GITHUB_ENTERPRISE=msft-demo-account-wEMU

# GitHub Organization (for Copilot seat data)
GITHUB_ORG=your-org-name

# Repos to track (comma-separated, owner/repo format)
GITHUB_REPOS=owner/repo1,owner/repo2,owner/repo3

# Dummy data settings
USE_DUMMY_DATA=true
DUMMY_SEED=42
DUMMY_DAYS=90
DUMMY_TEAM_SIZE=25
DUMMY_REPO_COUNT=5

# ROI calculator settings
TIME_SAVED_PER_ACCEPTANCE_SECONDS=55
DEVELOPER_HOURLY_RATE=75
